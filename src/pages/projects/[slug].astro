---
import Layout from '../../layouts/Layout.astro';
import { projects, type Project } from '../../data/projects';

interface Props {
  project: Project;
  prevProject: Project;
  nextProject: Project;
}

export async function getStaticPaths() {
  return projects.map((project, index) => {
    // Navigate in loop
    const prevProject = projects[index === 0 ? projects.length - 1 : index - 1];
    const nextProject = projects[index === projects.length - 1 ? 0 : index + 1];
    
    return {
      params: { slug: project.slug },
      props: { project, prevProject, nextProject },
    };
  });
}

const { project, prevProject, nextProject } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Layout 
  title={`${project.title} | Arath Portfolio`} 
  description={project.shortDescription}
  image={project.image}
>
  <div class="project-detail-container container">
    <!-- Back to Home Link -->
    <header class="detail-header animate-fade-in">
      <a href={base} class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Volver al inicio
      </a>
      <span class="completion-date">{project.completionDate}</span>
    </header>

    <!-- Title and Tags Section -->
    <section class="title-section animate-fade-in-up">
      <h1 class="project-title">{project.title}</h1>
      <div class="project-tags">
        {project.tags.map((tag) => <span class="badge">{tag}</span>)}
      </div>
    </section>

    <!-- Project Featured Image -->
    <section class="image-section animate-fade-in delay-1">
      <div class="image-container">
        <img src={`${base}${project.image.startsWith('/') ? project.image.slice(1) : project.image}`} alt={`Presentación detallada de ${project.title}`} class="featured-image" />
      </div>
    </section>

    <!-- Main Content Grid -->
    <section class="content-section animate-fade-in-up delay-2">
      <div class="content-grid">
        <!-- Project Description -->
        <div class="description-column">
          <h2 class="column-title">Sobre el proyecto</h2>
          <p class="project-text">{project.longDescription}</p>
          <p class="project-text">
            Este proyecto fue estructurado siguiendo metodologías ágiles de desarrollo, priorizando la refactorización constante de componentes y manteniendo una separación clara de responsabilidades para facilitar su escalamiento futuro.
          </p>
        </div>

        <!-- Project Metadata / Links Card -->
        <div class="meta-column">
          <div class="meta-card">
            <h3 class="meta-card-title">Detalles del Proyecto</h3>
            
            <div class="meta-item">
              <span class="meta-label">Año de finalización</span>
              <span class="meta-val">{project.completionDate}</span>
            </div>
            
            <div class="meta-item">
              <span class="meta-label">Categoría</span>
              <span class="meta-val">Desarrollo Web / Frontend</span>
            </div>

            <div class="meta-actions">
              <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-full">
                Demo en Vivo
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </a>
              <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-full">
                Ver Código
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                  <path d="M9 18c-4.51 2-5-2-7-2"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Navigation footer (Previous / Next) -->
    <footer class="project-navigation animate-fade-in delay-3">
      <a href={`${base}projects/${prevProject.slug}`} class="nav-project-link prev-project">
        <span class="nav-direction">Proyecto anterior</span>
        <span class="nav-title">{prevProject.title}</span>
      </a>
      <a href={`${base}projects/${nextProject.slug}`} class="nav-project-link next-project">
        <span class="nav-direction">Siguiente proyecto</span>
        <span class="nav-title">{nextProject.title}</span>
      </a>
    </footer>
  </div>
</Layout>

<style>
  .project-detail-container {
    padding-top: var(--space-md);
    padding-bottom: var(--space-lg);
  }

  /* Header & Back Link */
  .detail-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .back-link svg {
    transition: transform var(--transition-fast);
  }

  .back-link:hover svg {
    transform: translateX(-4px);
  }

  .completion-date {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Title section */
  .title-section {
    margin-bottom: var(--space-md);
  }

  .project-title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    margin-bottom: var(--space-xs);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* Featured Image */
  .image-section {
    margin-bottom: var(--space-lg);
  }

  .image-container {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-color);
    aspect-ratio: 16 / 9;
    box-shadow: 0 20px 50px -20px var(--shadow-color);
  }

  .featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Grid Layout */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  @media (min-width: 768px) {
    .content-grid {
      grid-template-columns: 1.3fr 0.7fr;
    }
  }

  .column-title {
    font-size: 1.5rem;
    margin-bottom: var(--space-sm);
    position: relative;
    padding-bottom: 0.5rem;
  }

  .column-title::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 30px;
    height: 2px;
    background-color: var(--color-primary);
  }

  .description-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .project-text {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Metadata Card */
  .meta-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    box-shadow: 0 15px 35px -15px var(--shadow-color);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .meta-card-title {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  .meta-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px dashed var(--border-color);
    font-size: 0.95rem;
  }

  .meta-item:last-of-type {
    border-bottom: none;
  }

  .meta-label {
    color: var(--text-secondary);
  }

  .meta-val {
    font-weight: 500;
    color: var(--text-primary);
  }

  .meta-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: var(--space-md);
  }

  .btn-full {
    width: 100%;
    justify-content: center;
  }

  /* Previous/Next Navigation */
  .project-navigation {
    display: grid;
    grid-template-columns: 1fr;
    border-top: 1px solid var(--border-color);
    padding-top: var(--space-md);
  }

  @media (min-width: 600px) {
    .project-navigation {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .nav-project-link {
    display: flex;
    flex-direction: column;
    padding: var(--space-sm);
    transition: background-color var(--transition-fast);
  }

  .nav-project-link:hover {
    background-color: var(--bg-secondary);
  }

  .prev-project {
    align-items: flex-start;
    border-bottom: 1px solid var(--border-color);
  }

  @media (min-width: 600px) {
    .prev-project {
      border-bottom: none;
      border-right: 1px solid var(--border-color);
    }
  }

  .next-project {
    align-items: flex-end;
  }

  .nav-direction {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 0.25rem;
    transition: color var(--transition-fast);
  }

  .nav-project-link:hover .nav-title {
    color: var(--color-primary);
  }
</style>
