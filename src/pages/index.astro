---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

// Meta description for SEO
const description = "Portafolio profesional de Arath. Desarrollador backend especializado en sistemas robustos, bases de datos optimizadas y arquitecturas escalables.";
---

<Layout title="Arath | Portfolio" description={description}>
  <!-- Hero Section -->
  <section class="hero container">
    <div class="hero-bg-blur"></div>
    <div class="hero-content animate-fade-in-up">
      <div class="hero-badge badge animate-fade-in delay-1">Disponible para nuevos proyectos</div>
      <h1 class="hero-title animate-fade-in-up delay-1">
        Backend <span class="gradient-text">robusto</span>, lógica precisa & sistemas que escalan.
      </h1>
      <p class="hero-subtitle animate-fade-in-up delay-2">
        Hola, soy Arath. Desarrollador backend especializado en construir sistemas sólidos, eficientes y bien estructurados. Me enfoco en la lógica de servidor, gestión de bases de datos y arquitecturas que funcionan a cualquier escala. Trabajo con herramientas como MySQL, Python, C++, Node.js y más.
      </p>
      <div class="hero-actions animate-fade-in-up delay-3">
        <a href="#proyectos" class="btn btn-primary">Ver mis proyectos</a>
        <a href="#contacto" class="btn btn-secondary">Hablemos</a>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="proyectos" class="projects-section">
    <div class="container">
      <div class="section-header animate-fade-in-up">
        <h2 class="section-title">Proyectos destacados</h2>
        <p class="section-subtitle">
          Una selección de trabajos recientes que muestran mis habilidades en diseño visual, desarrollo estructurado y optimización.
        </p>
      </div>

      <div class="grid-2 projects-grid">
        {projects.map((project) => (
          <div class="project-wrapper">
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Me Section -->
  <section id="sobre-mi" class="about-section container">
    <div class="about-grid">
      <div class="about-info animate-fade-in-up">
        <h2 class="section-title">Sobre mi filosofía</h2>
        <p class="about-text">
          Creo que un buen sistema backend es la columna vertebral de cualquier aplicación exitosa. Mi enfoque está en diseñar arquitecturas limpias, consultas SQL optimizadas y APIs confiables que soporten cualquier demanda de usuarios.
        </p>
        <p class="about-text">
          Cada línea de código que escribo está pensada para ser escalable, mantenible y eficiente en recursos. Me apasiona resolver problemas complejos de lógica de negocio, seguridad de datos y rendimiento de sistemas en producción.
        </p>
      </div>
      
      <div class="about-skills animate-fade-in-up delay-1">
        <h3 class="skills-title">Tecnologías y Herramientas</h3>
        <div class="skills-group">
          <span class="skill-tag">MySQL</span>
          <span class="skill-tag">Python</span>
          <span class="skill-tag">C++</span>
          <span class="skill-tag">Node.js</span>
          <span class="skill-tag">REST APIs</span>
          <span class="skill-tag">PostgreSQL</span>
          <span class="skill-tag">PHP</span>
          <span class="skill-tag">Linux / Bash</span>
          <span class="skill-tag">Git & GitHub</span>
          <span class="skill-tag">Docker</span>
          <span class="skill-tag">Arquitectura MVC</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contacto" class="contact-section">
    <div class="container contact-container">
      <div class="contact-card animate-fade-in-up">
        <div class="contact-info">
          <h2 class="contact-title">¿Tienes una idea en mente?</h2>
          <p class="contact-subtitle">
            Estoy disponible para trabajos freelance, contratos temporales o colaboraciones en proyectos interesantes. Escríbeme y lo conversamos.
          </p>
          <div class="contact-links">
            <a href="mailto:Carathrd@gmail.com" class="contact-link-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
              Carathrd@gmail.com
            </a>
            <a href="https://wa.me/59269929" target="_blank" rel="noopener noreferrer" class="contact-link-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
              WhatsApp: +502 5926-9929
            </a>
            <a href="https://instagram.com/Arath_Rivera" target="_blank" rel="noopener noreferrer" class="contact-link-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
              @Arath_Rivera
            </a>
            <span class="contact-link-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Guatemala, Guatemala
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    padding: var(--space-lg) 0;
    min-height: calc(85vh - 70px);
    display: flex;
    align-items: center;
  }

  .hero-bg-blur {
    position: absolute;
    top: 20%;
    right: 5%;
    width: clamp(250px, 40vw, 450px);
    height: clamp(250px, 40vw, 450px);
    background: radial-gradient(circle, var(--color-primary) 0%, transparent 70%);
    opacity: 0.15;
    filter: blur(80px);
    pointer-events: none;
    z-index: -1;
    transition: opacity var(--transition-medium);
  }

  :global([data-theme="light"]) .hero-bg-blur {
    opacity: 0.08;
  }

  .hero-content {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .hero-badge {
    margin-bottom: var(--space-xs);
  }

  .hero-title {
    font-weight: 800;
    line-height: 1.15;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2.5vw, 1.25rem);
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 700px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  /* Projects Section */
  .projects-section {
    padding: var(--space-lg) 0;
    background-color: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    transition: background-color var(--transition-medium), border-color var(--transition-medium);
  }

  .section-header {
    max-width: 600px;
    margin-bottom: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .section-title {
    position: relative;
    padding-bottom: 0.5rem;
  }

  .section-title::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 3px;
    background-color: var(--color-primary);
    border-radius: var(--radius-full);
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
  }

  .projects-grid {
    margin-top: var(--space-md);
  }

  /* About Section */
  .about-section {
    padding: var(--space-lg) 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 1.2fr 0.8fr;
      align-items: center;
    }
  }

  .about-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .about-text {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .about-skills {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    box-shadow: 0 10px 30px -20px var(--shadow-color);
  }

  .skills-title {
    font-size: 1.2rem;
    margin-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  .skills-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    transition: all var(--transition-fast);
  }

  .skill-tag:hover {
    border-color: var(--color-primary);
    background-color: var(--bg-primary);
    transform: scale(1.03);
  }

  /* Contact Section */
  .contact-section {
    padding: var(--space-lg) 0;
    background-color: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    transition: background-color var(--transition-medium), border-color var(--transition-medium);
  }

  .contact-container {
    max-width: 950px;
  }

  .contact-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    display: grid;
    grid-template-columns: 1fr;
    overflow: hidden;
    box-shadow: 0 20px 40px -20px var(--shadow-color);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  @media (min-width: 768px) {
    .contact-card {
      grid-template-columns: 1fr 1.1fr;
    }
  }

  .contact-info {
    padding: var(--space-md);
    background-color: hsla(240, 12%, 11%, 0.4);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-sm);
    border-bottom: 1px solid var(--border-color);
  }

  :global([data-theme="light"]) .contact-info {
    background-color: hsla(0, 0%, 95%, 0.5);
  }

  @media (min-width: 768px) {
    .contact-info {
      padding: var(--space-lg);
      border-bottom: none;
      border-right: 1px solid var(--border-color);
    }
  }

  .contact-title {
    font-size: 2rem;
  }

  .contact-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: var(--space-sm);
  }

  .contact-link-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.95rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  a.contact-link-item:hover {
    color: var(--color-primary);
  }

  /* Form */
  .contact-form {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .contact-form {
      padding: var(--space-lg);
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.03em;
  }

  .form-group input,
  .form-group textarea {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0.75rem 1rem;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    transition: all var(--transition-fast);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--border-glow);
    background-color: var(--bg-primary);
  }

  .btn-submit {
    margin-top: 0.5rem;
    align-self: flex-start;
    gap: 0.5rem;
  }
</style>
