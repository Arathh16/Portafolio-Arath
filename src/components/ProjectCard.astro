---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<article class="project-card glow-on-hover animate-fade-in-up">
  <div class="card-image-wrapper">
    <img src={`${base}${project.image.startsWith('/') ? project.image.slice(1) : project.image}`} alt={`Captura de pantalla de ${project.title}`} loading="lazy" class="card-image" />
    <div class="card-badge">{project.completionDate}</div>
  </div>
  
  <div class="card-content">
    <div class="card-tags">
      {project.tags.map((tag) => <span class="badge">{tag}</span>)}
    </div>
    
    <h3 class="card-title">
      <a href={`${base}projects/${project.slug}`}>{project.title}</a>
    </h3>
    
    <p class="card-description">{project.shortDescription}</p>
    
    <div class="card-actions">
      <a href={`${base}projects/${project.slug}`} class="link-more">
        Detalles
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="arrow-icon">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      
      <div class="links-external">
        <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" aria-label={`Ver código fuente de ${project.title} en GitHub`} class="external-icon-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
        </a>
        <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" aria-label={`Ver demo en vivo de ${project.title}`} class="external-icon-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
        </a>
      </div>
    </div>
  </div>
</article>

<style>
  .project-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-shadow: 0 10px 30px -15px var(--shadow-color);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: transform var(--transition-medium), border-color var(--transition-medium), box-shadow var(--transition-medium);
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-primary);
    box-shadow: 0 15px 35px -10px var(--shadow-color), 0 0 25px -5px var(--border-glow);
  }

  .card-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background-color: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .project-card:hover .card-image {
    transform: scale(1.04);
  }

  .card-badge {
    position: absolute;
    top: var(--space-xs);
    right: var(--space-xs);
    background-color: rgba(0, 0, 0, 0.7);
    color: white;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    backdrop-filter: blur(4px);
  }

  .card-content {
    padding: var(--space-sm);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .card-content {
      padding: var(--space-md);
    }
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-title {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .card-title a {
    color: var(--text-primary);
    display: block;
  }

  .card-title a:hover {
    color: var(--color-primary);
  }

  .card-description {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-grow: 1;
  }

  .card-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--border-color);
    margin-top: auto;
  }

  .link-more {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .link-more:hover {
    color: var(--color-primary-hover);
  }

  .arrow-icon {
    transition: transform var(--transition-fast);
  }

  .link-more:hover .arrow-icon {
    transform: translateX(3px);
  }

  .links-external {
    display: flex;
    gap: 0.75rem;
  }

  .external-icon-link {
    color: var(--text-muted);
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .external-icon-link:hover {
    color: var(--text-primary);
    transform: scale(1.1);
  }
</style>
